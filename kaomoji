#!/usr/bin/env bash

# Cache configuration
CACHE_DIR="${XDG_CACHE_HOME:-"$HOME/.cache"}/vmenu"
CACHE_FILE="$CACHE_DIR/kaomojis.txt"

# Default options
ACTION="copy" # copy or type
NO_NOTIFY=1

# Help message
show_help() {
    cat <<EOF
Usage: kaomoji [options] [-- [vmenu options]]

A kaomoji picker script using vmenu.

Options:
  -u, --update      Re-initialize the local kaomoji database.
  -t, --type        Type the selected kaomoji directly using xdotool/wtype instead of copying.
  -c, --copy        Copy the selected kaomoji to clipboard (default).
  -n, --notify      Show a desktop notification after selection.
  -h, --help        Show this help message.

Any options after -- are passed directly to vmenu.
EOF
}

